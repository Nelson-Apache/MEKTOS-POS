<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane
    xmlns:fx="http://javafx.com/fxml/1"
    xmlns="http://javafx.com/javafx/21"
    fx:controller="com.nap.pos.ui.controller.MainWindowController"
    stylesheets="@../css/styles.css">

    <!-- ══════════════════════════════════════════════════════
         SIDEBAR — navegación lateral (colapsable)
         ══════════════════════════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar">

            <!-- Brand / nombre tienda -->
            <VBox fx:id="brandArea" styleClass="sidebar-brand-area">
                <Label fx:id="lblAppName" text="NAP POS" styleClass="sidebar-app-name"/>
                <Label fx:id="lblNombreTienda" text="" styleClass="sidebar-store-name"/>
            </VBox>

            <!-- Separador -->
            <Region fx:id="sepBrand" styleClass="sidebar-sep" maxHeight="1" minHeight="1"/>

            <!-- Grupo: Menú Principal -->
            <Label fx:id="lblGrupoPrincipal" text="MENÚ PRINCIPAL" styleClass="sidebar-group-label"/>

            <Button fx:id="btnDashboard"
                    text="Dashboard"
                    styleClass="nav-item"
                    onAction="#navDashboard"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-th-large" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnVentas"
                    text="Ventas"
                    styleClass="nav-item"
                    onAction="#navVentas"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-receipt" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnInventario"
                    text="Inventario"
                    styleClass="nav-item"
                    onAction="#navInventario"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-boxes" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnCompras"
                    text="Compras"
                    styleClass="nav-item"
                    onAction="#navCompras"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-shopping-basket" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnClientes"
                    text="Clientes"
                    styleClass="nav-item"
                    onAction="#navClientes"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnProveedores"
                    text="Proveedores"
                    styleClass="nav-item"
                    onAction="#navProveedores"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-truck" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <!-- Grupo: Administración -->
            <Label fx:id="lblGrupoAdmin" text="ADMINISTRACIÓN" styleClass="sidebar-group-label"/>

            <Button fx:id="btnCaja"
                    text="Caja"
                    styleClass="nav-item"
                    onAction="#navCaja"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnReportes"
                    text="Reportes"
                    styleClass="nav-item"
                    onAction="#navReportes"
                    maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <Button fx:id="btnConfiguracion"
                    text="Configuración"
                    styleClass="nav-item"
                    onAction="#navConfiguracion"
                    maxWidth="Infinity"
                    visible="false"
                    managed="false">
                <graphic><FontIcon iconLiteral="fas-cog" iconSize="14" styleClass="nav-icon"/></graphic>
            </Button>

            <!-- Relleno para empujar usuario al fondo -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Separador -->
            <Region fx:id="sepBottom" styleClass="sidebar-sep" maxHeight="1" minHeight="1"/>

            <!-- Separador -->
            <Region styleClass="sidebar-sep" maxHeight="1" minHeight="1"/>

            <!-- Usuario activo -->
            <VBox fx:id="userArea" styleClass="sidebar-user-area">
                <Label fx:id="lblUsername" text="" styleClass="sidebar-username"/>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label fx:id="lblRol" text="" styleClass="sidebar-rol"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnCerrarSesion"
                            text="Cerrar sesión"
                            styleClass="sidebar-logout"
                            onAction="#onCerrarSesion"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════════════
         ÁREA CENTRAL — topbar + contenido dinámico
         ══════════════════════════════════════════════════════ -->
    <center>
        <VBox>

            <!-- Barra superior -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="8">

                <!-- Toggle sidebar -->
                <Button fx:id="btnToggleSidebar"
                        styleClass="topbar-action-btn"
                        onAction="#onToggleSidebar">
                    <graphic><FontIcon iconLiteral="fas-bars" iconSize="16"/></graphic>
                </Button>

                <Label fx:id="lblSeccion" text="" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Badge de estado de caja -->
                <HBox fx:id="hboxCajaBadge" styleClass="caja-badge caja-cerrada"
                      alignment="CENTER_LEFT" spacing="5">
                    <Label fx:id="lblCaja" text="Sin caja abierta"
                           styleClass="caja-badge-text-cerrada"/>
                </HBox>

                <!-- Notificaciones -->
                <Button fx:id="btnNotificaciones"
                        styleClass="topbar-action-btn"
                        onAction="#onNotificaciones">
                    <graphic><FontIcon iconLiteral="fas-bell" iconSize="16"/></graphic>
                </Button>

                <!-- Chip de usuario -->
                <HBox styleClass="user-chip" alignment="CENTER">
                    <Label fx:id="lblUserChip" text="" styleClass="user-chip-text"/>
                </HBox>

            </HBox>

            <!-- Contenido — se inyectan módulos aquí -->
            <StackPane fx:id="contenido" styleClass="content-area" VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

</BorderPane>
