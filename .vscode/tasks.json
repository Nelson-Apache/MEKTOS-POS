{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "NAP POS: Ejecutar",
            "type": "shell",
            "command": ".\\gradlew.bat bootRun",
            "options": {
                "cwd": "${workspaceFolder}/sistemapos"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "NAP POS: Compilar",
            "type": "shell",
            "command": ".\\gradlew.bat compileJava",
            "options": {
                "cwd": "${workspaceFolder}/sistemapos"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$javac"]
        },
        {
            "label": "NAP POS: Tests",
            "type": "shell",
            "command": ".\\gradlew.bat test",
            "options": {
                "cwd": "${workspaceFolder}/sistemapos"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        }
    ]
}
