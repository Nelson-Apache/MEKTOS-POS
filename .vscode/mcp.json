{
	"servers": {
		"figma": {
			"command": "npx",
			"args": [
				"-y",
				"figma-developer-mcp"
			],
			"env": {
				"FIGMA_API_KEY": "${input:figma-api-key}"
			},
			"type": "stdio"
		}
	},
	"inputs": [
		{
			"type": "promptString",
			"id": "figma-api-key",
			"description": "Figma API Key",
			"password": true
		}
	]
}